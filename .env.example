# Copy this file to `.env` and fill in real values. `.env` is
# gitignored — never commit it.
#
# docker-compose.yml loads `.env` via `env_file:`; the container sees
# these as real environment variables, and config/runtime.exs reads
# them with System.get_env/1.

# --- REQUIRED -----------------------------------------------------------------

# Cookie / LiveView signing secret. Generate with:
#   mix phx.gen.secret
# Must be at least 64 bytes. Changing it invalidates every signed token.
SECRET_KEY_BASE=

# Public hostname the app is served under. Used for URL generation in
# LiveView redirects and CSRF origin checks. For local-network-only,
# the NAS's hostname or LAN IP (e.g. nas.local, 192.168.1.42).
PHX_HOST=nas.local

# Drive service-account credentials are NOT an env var any more —
# upload the JSON key through the app's /settings page; it's stored
# in the app database.

# --- TUNING (optional) --------------------------------------------------------

# Scheduler tick interval in milliseconds. Default 3600000 = 1h.
# Set something small (e.g. 60000 = 1m) while testing.
# SYNZ_TICK_INTERVAL_MS=3600000

# Ecto pool size. Default 5 is fine for one-user NAS.
# POOL_SIZE=5

# --- HOST-SIDE (read by docker-compose, not by the app) -----------------------

# Published port on the host. Keep 4000 unless something else on the
# NAS wants it.
HOST_PORT=4000

# UID/GID to build the image with. Set to $(id -u)/$(id -g) of the
# Synology user that owns your source folders so bind mounts are
# readable without chown.
APP_UID=1000
APP_GID=1000

# Host path for the SQLite DB. The compose file uses this via
# ${DATA_DIR}. Relative paths are resolved against the Docker
# *daemon's* working directory, which is the Mac for local dev and
# the NAS when using a remote context — use an absolute path for NAS
# deploys so the location is deterministic.
# DATA_DIR=./data

# Pull a pre-built image from a registry instead of building locally.
# For the GitHub Actions workflow, set this on the NAS to
#   ghcr.io/<your-gh-user>/synology_zipper:latest
# and run `docker compose pull && docker compose up -d`. Leave unset
# to use the locally-built `synology_zipper:latest` image.
# SYNZ_IMAGE=ghcr.io/<user>/synology_zipper:latest
